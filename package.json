{
  "name": "subzero",
  "module": "src/index.ts",
  "type": "module",
  "devDependencies": {
    "@types/bun": "latest",
    "@types/ip": "^1.1.3",
    "husky": "^9.1.7"
  },
  "scripts": {
    "clean": "rm -rf dist && echo 'Done.'",
    "start": "bun run build && bun dist/index.js",
    "dev:server": "bun src/index.ts",
    "build": "bun build src/index.ts --outdir dist --target bun",
    "watch:server": "bun --watch run dev:server",
    "watch:client": "bun --watch run dev:client",
    "test": "bun test",
    "cov": "bun test --coverage"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "dependencies": {
    "@noble/ed25519": "^3.0.0",
    "@noble/hashes": "^2.0.1",
    "@types/level": "^8.0.0",
    "canonicalize": "^2.1.0",
    "ip": "^2.0.1",
    "level-ts": "^2.1.0",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "zod": "^4.3.6"
  }
}
